{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/overdue-check",
      "schedule": "0 1 * * 1-5"
    },
    {
      "path": "/api/daily-digest",
      "schedule": "5 1 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
